# AI News Pulse - Environment Variables Template

# Groq LLM API Key (required for RAG digest generation)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Pinecone Vector Store API Key (required for storing and retrieving embeddings)
PINECONE_API_KEY=pc-your_pinecone_api_key_here

# PostgreSQL Database Connection String (required for storing articles and digests)
# Format: postgresql://user:password@host:port/dbname
# Default local docker-compose connection:
DATABASE_URL=postgresql://ainewspulse:password123@localhost:5432/ainewspulse

# SendGrid API Key (optional - only needed for Phase 6 email delivery)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
